<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tin Shade Noida | Professional Tin Shed & MS Structure Manufacturer</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    :root {
      --orange:#e8620a; --orange-d:#c0500a; --orange-lt:#fff3ec;
      --blue:#1a3a6b; --dark:#111827; --grey:#6b7280; --grey-lt:#e5e7eb;
      --white:#ffffff; --green:#16a34a;
      --shadow:0 4px 24px rgba(0,0,0,.10);
    }
    html { scroll-behavior:smooth; }
    body { font-family:'Poppins',sans-serif; background:var(--white); color:var(--dark); overflow-x:hidden; }

    /* TOPBAR */
    .topbar { background:var(--blue); padding:.45rem 0; }
    .topbar-inner { max-width:1200px; margin:0 auto; padding:0 1.5rem; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:.5rem; }
    .topbar-info { display:flex; gap:1.8rem; flex-wrap:wrap; }
    .ti { display:flex; align-items:center; gap:.4rem; font-size:.72rem; color:rgba(255,255,255,.85); }
    .ti span { color:var(--orange); }
    .topbar-actions { display:flex; gap:.7rem; }
    .tbtn { display:flex; align-items:center; gap:.35rem; padding:.3rem .9rem; border-radius:3px; font-size:.7rem; font-weight:600; text-decoration:none; }
    .tbtn.call { background:var(--orange); color:#fff; }
    .tbtn.wa   { background:#25d366; color:#fff; }
    .tbtn:hover { opacity:.85; }

    /* NAV */
    nav { background:var(--white); box-shadow:0 2px 12px rgba(0,0,0,.08); position:sticky; top:0; z-index:500; }
    .nav-inner { max-width:1200px; margin:0 auto; padding:0 1.5rem; display:flex; align-items:center; justify-content:space-between; height:68px; }
    .nav-logo { display:flex; align-items:center; gap:.8rem; text-decoration:none; }
    .nav-logo-icon { width:46px; height:46px; background:var(--orange); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:1.4rem; flex-shrink:0; }
    .nav-logo-name { font-size:1.05rem; font-weight:700; color:var(--blue); line-height:1.2; }
    .nav-logo-tag  { font-size:.62rem; color:var(--grey); }
    .nav-links { display:flex; list-style:none; }
    .nav-links a { display:block; padding:.5rem 1rem; font-size:.8rem; font-weight:500; color:var(--dark); text-decoration:none; border-radius:4px; transition:background .2s,color .2s; }
    .nav-links a:hover { background:var(--orange-lt); color:var(--orange); }
    .nav-quote { background:var(--orange) !important; color:#fff !important; border-radius:6px !important; font-weight:600 !important; }
    .nav-quote:hover { background:var(--orange-d) !important; }
    .hbg { display:none; background:none; border:none; font-size:1.5rem; cursor:pointer; color:var(--dark); }

    /* SLIDER */
    .slider-wrap { position:relative; overflow:hidden; height:520px; }
    .slides { display:flex; height:100%; transition:transform .55s cubic-bezier(.4,0,.2,1); }
    .slide { min-width:100%; height:520px; position:relative; display:flex; align-items:center; }
    .slide-bg { position:absolute; inset:0; background-size:cover; background-position:center; }
    .sl-overlay { position:absolute; inset:0; background:linear-gradient(90deg,rgba(8,18,48,.85) 40%,rgba(8,18,48,.3) 100%); }
    .sl-content { position:relative; z-index:2; max-width:1200px; margin:0 auto; width:100%; padding:0 2.5rem; }
    .sl-badge { display:inline-block; background:var(--orange); color:#fff; font-size:.68rem; font-weight:700; letter-spacing:.1em; padding:.28rem .85rem; border-radius:3px; margin-bottom:1rem; text-transform:uppercase; }
    .sl-title { font-size:clamp(1.9rem,4.5vw,3.2rem); font-weight:800; color:#fff; line-height:1.15; margin-bottom:.75rem; }
    .sl-sub { font-size:.98rem; color:rgba(255,255,255,.8); margin-bottom:1.8rem; font-weight:300; }
    .sl-btns { display:flex; gap:.8rem; flex-wrap:wrap; }
    .sbtn { padding:.75rem 1.8rem; border-radius:5px; font-size:.83rem; font-weight:600; text-decoration:none; font-family:'Poppins',sans-serif; border:none; cursor:pointer; transition:transform .2s,box-shadow .2s; }
    .sbtn:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(0,0,0,.25); }
    .sbtn.p { background:var(--orange); color:#fff; }
    .sbtn.s { background:#fff; color:var(--blue); }
    .sl-arrow { position:absolute; top:50%; transform:translateY(-50%); width:42px; height:42px; border-radius:50%; background:rgba(255,255,255,.18); border:2px solid rgba(255,255,255,.45); color:#fff; font-size:1.1rem; display:flex; align-items:center; justify-content:center; cursor:pointer; z-index:10; transition:background .2s; }
    .sl-arrow:hover { background:var(--orange); border-color:var(--orange); }
    .sl-arrow.prv { left:1.2rem; }
    .sl-arrow.nxt { right:1.2rem; }
    .sl-dots { position:absolute; bottom:1rem; left:50%; transform:translateX(-50%); display:flex; gap:.5rem; z-index:10; }
    .dot { width:10px; height:10px; border-radius:50%; background:rgba(255,255,255,.38); cursor:pointer; transition:background .2s,transform .2s; }
    .dot.on { background:var(--orange); transform:scale(1.3); }

    /* COMMONS */
    .sw { max-width:1200px; margin:0 auto; }
    .sh { text-align:center; margin-bottom:3rem; }
    .eyebrow { display:inline-block; background:var(--orange-lt); color:var(--orange); font-size:.68rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; padding:.28rem .85rem; border-radius:3px; margin-bottom:.8rem; }
    .ttl { font-size:clamp(1.5rem,3vw,2.2rem); font-weight:800; color:var(--blue); line-height:1.2; margin-bottom:.5rem; }
    .ttl em { color:var(--orange); font-style:normal; }
    .sh p { font-size:.9rem; color:var(--grey); max-width:540px; margin:.5rem auto 0; }

    /* ABOUT */
    #about { padding:5rem 1.5rem; }
    .about-g { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; }
    .about-img-wrap { position:relative; }
    .about-img { width:100%; border-radius:10px; height:380px; background:linear-gradient(135deg,#1a3a6b,#2352a0); display:flex; align-items:center; justify-content:center; font-size:7rem; color:rgba(255,255,255,.12); }
    .ab-badge { position:absolute; bottom:-1.2rem; right:-.8rem; background:var(--orange); color:#fff; border-radius:10px; padding:1rem 1.4rem; text-align:center; box-shadow:var(--shadow); }
    .ab-badge .n { font-size:1.8rem; font-weight:800; line-height:1; }
    .ab-badge .l { font-size:.62rem; opacity:.9; margin-top:.2rem; }
    .ab-txt { font-size:.9rem; color:var(--grey); line-height:1.8; margin-bottom:.9rem; }
    .ab-pts { list-style:none; display:flex; flex-direction:column; gap:.55rem; margin-bottom:1.5rem; }
    .ab-pts li { display:flex; align-items:flex-start; gap:.7rem; font-size:.85rem; color:var(--dark); }
    .ab-pts li::before { content:'✓'; width:20px; height:20px; flex-shrink:0; background:var(--green); color:#fff; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.58rem; font-weight:700; margin-top:.1rem; }
    .ab-stats { display:flex; gap:2rem; padding-top:1.4rem; border-top:1px solid var(--grey-lt); flex-wrap:wrap; }
    .as-num { font-size:1.9rem; font-weight:800; color:var(--orange); line-height:1; }
    .as-lbl { font-size:.65rem; color:var(--grey); margin-top:.15rem; font-weight:500; }

    /* SERVICES */
    #services { padding:5rem 1.5rem; background:#f8fafc; }
    .srv-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.4rem; }
    .srv-card { background:#fff; border-radius:10px; padding:1.8rem; box-shadow:var(--shadow); border-top:4px solid transparent; transition:border-color .3s,transform .3s; }
    .srv-card:hover { border-color:var(--orange); transform:translateY(-4px); }
    .srv-ico { width:52px; height:52px; border-radius:10px; background:var(--orange-lt); display:flex; align-items:center; justify-content:center; font-size:1.5rem; margin-bottom:1rem; }
    .srv-name { font-size:.98rem; font-weight:700; color:var(--blue); margin-bottom:.45rem; }
    .srv-desc { font-size:.81rem; color:var(--grey); line-height:1.7; }

    /* PROJECTS */
    #projects { padding:5rem 1.5rem; }
    .prj-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1.4rem; }
    .prj-card { border-radius:10px; overflow:hidden; box-shadow:var(--shadow); position:relative; transition:transform .3s; }
    .prj-card:hover { transform:translateY(-4px); }
    .prj-img { height:210px; display:flex; align-items:center; justify-content:center; font-size:4rem; }
    .g1{background:linear-gradient(135deg,#1a3a6b,#2352a0);color:rgba(255,255,255,.15);}
    .g2{background:linear-gradient(135deg,#0d2a1b,#1a5c3a);color:rgba(255,255,255,.15);}
    .g3{background:linear-gradient(135deg,#2a1a0d,#5c3a1a);color:rgba(255,255,255,.15);}
    .g4{background:linear-gradient(135deg,#1a1a3a,#3a3a6b);color:rgba(255,255,255,.15);}
    .g5{background:linear-gradient(135deg,#0d1a2a,#1a3a5c);color:rgba(255,255,255,.15);}
    .g6{background:linear-gradient(135deg,#2a0d0d,#6b1a1a);color:rgba(255,255,255,.15);}
    .prj-done { position:absolute; top:1rem; left:1rem; background:var(--green); color:#fff; font-size:.62rem; font-weight:600; padding:.22rem .65rem; border-radius:3px; }
    .prj-info { padding:1.1rem 1.3rem; background:#fff; }
    .prj-name { font-size:.92rem; font-weight:700; color:var(--blue); margin-bottom:.3rem; }
    .prj-det  { font-size:.76rem; color:var(--grey); }
    .prj-tags { display:flex; gap:.6rem; margin-top:.5rem; flex-wrap:wrap; }
    .prj-tags span { font-size:.66rem; background:var(--orange-lt); color:var(--orange); padding:.15rem .55rem; border-radius:3px; font-weight:600; }

    /* WHY US */
    #why { padding:5rem 1.5rem; background:var(--blue); }
    #why .ttl { color:#fff; }
    #why .eyebrow { background:rgba(255,255,255,.12); color:#fff; }
    #why .sh p { color:rgba(255,255,255,.65); }
    .why-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.4rem; }
    .why-card { background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.11); border-radius:10px; padding:1.8rem 1.4rem; text-align:center; transition:background .3s; }
    .why-card:hover { background:rgba(255,255,255,.13); }
    .why-ico { font-size:2.2rem; margin-bottom:.9rem; display:block; }
    .why-ttl { font-size:.95rem; font-weight:700; color:#fff; margin-bottom:.45rem; }
    .why-dsc { font-size:.8rem; color:rgba(255,255,255,.62); line-height:1.7; }

    /* CLIENTS */
    #clients { padding:4rem 1.5rem; background:#f8fafc; }
    .cl-row { display:flex; gap:1.2rem; flex-wrap:wrap; justify-content:center; margin-top:2rem; }
    .cl-badge { background:#fff; border-radius:8px; padding:.9rem 1.5rem; box-shadow:var(--shadow); text-align:center; min-width:148px; }
    .cl-name { font-size:.8rem; font-weight:700; color:var(--blue); }
    .cl-loc  { font-size:.68rem; color:var(--grey); margin-top:.15rem; }

    /* TESTIMONIALS */
    #testimonials { padding:5rem 1.5rem; }
    .tst-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.4rem; }
    .tst-card { background:#f8fafc; border-radius:10px; padding:1.8rem; border-left:4px solid var(--orange); box-shadow:var(--shadow); }
    .tst-stars { color:#f59e0b; font-size:.88rem; margin-bottom:.7rem; }
    .tst-txt  { font-size:.85rem; color:var(--grey); line-height:1.75; font-style:italic; margin-bottom:1.1rem; }
    .tst-name { font-size:.86rem; font-weight:700; color:var(--blue); }
    .tst-role { font-size:.7rem; color:var(--grey); margin-top:.15rem; }

    /* GALLERY */
    #gallery { padding:5rem 1.5rem; background:#f8fafc; }
    .gal-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; }
    .gal-item { border-radius:8px; overflow:hidden; height:200px; display:flex; align-items:center; justify-content:center; font-size:3.5rem; cursor:pointer; position:relative; transition:transform .3s; }
    .gal-item:hover { transform:scale(1.03); }
    .gal-ov { position:absolute; inset:0; background:rgba(26,58,107,.65); display:flex; align-items:center; justify-content:center; opacity:0; transition:opacity .3s; color:#fff; font-size:.9rem; font-weight:600; }
    .gal-item:hover .gal-ov { opacity:1; }

    /* VIDEOS */
    #videos { padding:5rem 1.5rem; }
    .vid-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:1rem; }
    .vid-card { border-radius:8px; overflow:hidden; box-shadow:var(--shadow); cursor:pointer; transition:transform .3s; }
    .vid-card:hover { transform:translateY(-3px); }
    .vid-thumb { height:118px; background:linear-gradient(135deg,#1a3a6b,#2352a0); display:flex; align-items:center; justify-content:center; }
    .vid-play { width:36px; height:36px; border-radius:50%; background:rgba(232,98,10,.9); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.8rem; }
    .vid-lbl { padding:.55rem .8rem; background:#fff; }
    .vid-ttl { font-size:.7rem; font-weight:600; color:var(--dark); }
    .vid-sub { font-size:.62rem; color:var(--grey); margin-top:.1rem; }
    .ig-cta { text-align:center; margin-top:2rem; }
    .ig-btn { display:inline-flex; align-items:center; gap:.55rem; background:linear-gradient(135deg,#833ab4,#fd1d1d,#fcb045); color:#fff; padding:.7rem 1.8rem; border-radius:25px; text-decoration:none; font-size:.83rem; font-weight:600; }
    .ig-btn:hover { opacity:.9; }

    /* CTA BAND */
    .cta-band { background:linear-gradient(135deg,var(--orange),var(--orange-d)); padding:4rem 1.5rem; text-align:center; }
    .cta-band h2 { font-size:clamp(1.5rem,3vw,2.3rem); font-weight:800; color:#fff; margin-bottom:.6rem; }
    .cta-band p  { font-size:.95rem; color:rgba(255,255,255,.85); margin-bottom:1.8rem; }
    .cta-btns { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }
    .cbtn { display:flex; align-items:center; gap:.5rem; padding:.8rem 2rem; border-radius:6px; font-size:.88rem; font-weight:700; text-decoration:none; font-family:'Poppins',sans-serif; transition:transform .2s; }
    .cbtn:hover { transform:translateY(-2px); }
    .cbtn.w { background:#fff; color:var(--orange); }
    .cbtn.g { background:#25d366; color:#fff; }

    /* CONTACT */
    #contact { padding:5rem 1.5rem; background:#f8fafc; }
    .ct-inner { max-width:1200px; margin:2.5rem auto 0; display:grid; grid-template-columns:1fr 1fr; gap:3.5rem; }
    .ct-rows { display:flex; flex-direction:column; gap:.9rem; margin-top:1.5rem; }
    .ct-row { display:flex; align-items:center; gap:1rem; background:#fff; border-radius:8px; padding:.95rem 1.1rem; box-shadow:0 2px 8px rgba(0,0,0,.06); text-decoration:none; color:var(--dark); transition:box-shadow .2s,transform .2s; }
    .ct-row:hover { box-shadow:0 4px 16px rgba(0,0,0,.1); transform:translateX(4px); }
    .ct-ico { width:40px; height:40px; border-radius:8px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:1.05rem; }
    .ico-o{background:var(--orange-lt);} .ico-g{background:#dcfce7;} .ico-b{background:#e0f2fe;} .ico-p{background:#f3e8ff;}
    .ct-lbl { font-size:.62rem; font-weight:600; color:var(--grey); text-transform:uppercase; letter-spacing:.08em; }
    .ct-val { font-size:.88rem; font-weight:600; color:var(--dark); margin-top:.08rem; }
    .cf-box { background:#fff; border-radius:12px; padding:2.2rem; box-shadow:var(--shadow); }
    .cf-box h3 { font-size:1.05rem; font-weight:700; color:var(--blue); margin-bottom:1.4rem; }
    .cf { display:flex; flex-direction:column; gap:.9rem; }
    .cf-row2 { display:grid; grid-template-columns:1fr 1fr; gap:.9rem; }
    .cfg { display:flex; flex-direction:column; gap:.32rem; }
    .cfg label { font-size:.65rem; font-weight:600; color:var(--grey); text-transform:uppercase; letter-spacing:.08em; }
    .cfg input,.cfg select,.cfg textarea { border:1px solid var(--grey-lt); border-radius:6px; padding:.65rem .9rem; font-family:'Poppins',sans-serif; font-size:.83rem; color:var(--dark); outline:none; transition:border-color .2s; resize:none; }
    .cfg input:focus,.cfg select:focus,.cfg textarea:focus { border-color:var(--orange); }
    .cfg textarea { height:105px; }
    .cf-submit { background:var(--orange); color:#fff; border:none; border-radius:6px; padding:.82rem; font-family:'Poppins',sans-serif; font-size:.88rem; font-weight:700; cursor:pointer; width:100%; transition:background .2s; }
    .cf-submit:hover { background:var(--orange-d); }

    /* FOOTER */
    footer { background:var(--dark); color:rgba(255,255,255,.72); padding:4rem 1.5rem 0; }
    .ft-grid { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:2fr 1fr 1fr 1.2fr; gap:2.5rem; padding-bottom:2.8rem; border-bottom:1px solid rgba(255,255,255,.07); }
    .ft-bname { font-size:1.05rem; font-weight:700; color:#fff; margin-bottom:.25rem; }
    .ft-btag  { font-size:.72rem; color:var(--orange); margin-bottom:.9rem; }
    .ft-about { font-size:.8rem; line-height:1.75; color:rgba(255,255,255,.5); margin-bottom:1.1rem; }
    .ft-soc { display:flex; gap:.55rem; }
    .fsoc { width:32px; height:32px; border-radius:6px; background:rgba(255,255,255,.08); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.8rem; text-decoration:none; transition:background .2s; }
    .fsoc:hover { background:var(--orange); }
    .ft-col h4 { font-size:.76rem; font-weight:700; color:#fff; margin-bottom:.9rem; text-transform:uppercase; letter-spacing:.08em; }
    .ft-list { list-style:none; display:flex; flex-direction:column; gap:.45rem; }
    .ft-list a { font-size:.78rem; color:rgba(255,255,255,.5); text-decoration:none; display:flex; align-items:center; gap:.35rem; transition:color .2s; }
    .ft-list a:hover { color:var(--orange); }
    .ft-list a::before { content:'›'; color:var(--orange); }
    .ft-ci { display:flex; align-items:flex-start; gap:.65rem; font-size:.78rem; color:rgba(255,255,255,.5); margin-bottom:.75rem; }
    .ft-ci span { color:var(--orange); flex-shrink:0; }
    .ft-bottom { max-width:1200px; margin:0 auto; padding:1.1rem 0; }
    .ft-copy { font-size:.72rem; color:rgba(255,255,255,.38); }

    /* FLOATERS */
    .floaters { position:fixed; bottom:1.5rem; right:1.5rem; display:flex; flex-direction:column; gap:.65rem; z-index:800; }
    .fb { width:50px; height:50px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.25rem; text-decoration:none; box-shadow:0 4px 16px rgba(0,0,0,.22); transition:transform .2s; }
    .fb:hover { transform:scale(1.12); }
    .fb.call { background:var(--orange); color:#fff; }
    .fb.wa   { background:#25d366; color:#fff; }

    /* RESPONSIVE */
    @media(max-width:960px){
      .topbar-info{display:none;} .nav-links{display:none;} .hbg{display:block;}
      .slider-wrap,.slide{height:380px;}
      .about-g{grid-template-columns:1fr;gap:2.5rem;}
      .about-img{height:220px;} .ab-badge{right:0;bottom:-1rem;}
      .srv-grid{grid-template-columns:1fr 1fr;}
      .prj-grid{grid-template-columns:1fr;}
      .why-grid{grid-template-columns:1fr 1fr;}
      .tst-grid{grid-template-columns:1fr;}
      .gal-grid{grid-template-columns:1fr 1fr;}
      .vid-grid{grid-template-columns:repeat(2,1fr);}
      .ct-inner{grid-template-columns:1fr;}
      .ft-grid{grid-template-columns:1fr 1fr;}
      .cf-row2{grid-template-columns:1fr;}
    }
    @media(max-width:560px){
      .srv-grid{grid-template-columns:1fr;} .why-grid{grid-template-columns:1fr;}
      .gal-grid{grid-template-columns:1fr;} .ft-grid{grid-template-columns:1fr;}
    }
  </style>
</head>
