<script>
  // SLIDER
  let cur=0, tot=4;
  const slidesEl=document.getElementById('slides');
  const dots=document.querySelectorAll('.dot');
  function goSlide(n){ cur=((n%tot)+tot)%tot; slidesEl.style.transform='translateX(-'+cur*100+'%)'; dots.forEach((d,i)=>d.classList.toggle('on',i===cur)); }
  function chSlide(d){ goSlide(cur+d); }
  setInterval(()=>chSlide(1),5000);

  // HAMBURGER
  const hbg=document.getElementById('hbg');
  const navLinks=document.getElementById('navLinks');
  let open=false;
  hbg.addEventListener('click',()=>{
    open=!open;
    hbg.textContent=open?'✕':'☰';
    Object.assign(navLinks.style,open?{display:'flex',flexDirection:'column',position:'absolute',top:'68px',left:'0',right:'0',background:'#fff',padding:'1rem 1.5rem 1.5rem',boxShadow:'0 8px 24px rgba(0,0,0,.12)',zIndex:'999'}:{display:''});
  });
  navLinks.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{ if(open){open=false;hbg.textContent='☰';navLinks.style.display='';} }));
</script>
